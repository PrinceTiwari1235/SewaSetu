# Copy this file to .env.local and fill in your values.
# In Vercel, add the same keys in Project Settings -> Environment Variables.

# Database (Neon / PostgreSQL)
# DATABASE_URL should use the pooled endpoint for serverless runtimes.
# DIRECT_URL should use the direct endpoint for Prisma migrate/db push.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_POOLED_HOST/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@YOUR_DIRECT_HOST/neondb?sslmode=require

# NextAuth.js
# For local dev keep localhost; for production use your Vercel domain.
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000

# Optional OAuth providers (only if configured in auth providers)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_ID=your-github-app-client-id
# GITHUB_SECRET=your-github-app-client-secret
